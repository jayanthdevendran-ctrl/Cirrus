import subprocess
import time
from PIL import ImageFont
from gpiozero import Button
from luma.core.interface.serial import spi
from luma.lcd.device import ili9341
from luma.core.render import canvas
serial = spi(port=0, device=0, gpio_DC=25, gpio_RST=27)
device = ili9341(serial, width=320, height=240)

down = Button(26)
up = Button(24)
select = Button(19)
main_menu = ["MP3", "PS1", "Settings", "Power Off"]
indmain = 0
indsub = 0
MP3 = ["Liked songs", "Playlists", "Go back" ]

def draw_main(main_menu, selected_index):
    with canvas(device) as draw:
        for index, item in enumerate(main_menu):
            if index == selected_index:
                draw.text((10, 15*(index+1)), item, fill = "yellow")
            else:
                draw.text((10, 15*(index+1)), item, fill = "white")

def draw_submenu(sub_menu, selected_index):
    with canvas(device) as draw:
        for index, item in enumerate(sub_menu):
            if index == selected_index:
                draw.text((10, 15*(index+1)), item, fill = "yellow")
            else:
                draw.text((10, 15*(index+1)), item, fill = "white")

draw_main(main_menu, 0)
currentmenu = 99
while True:
    downtrue = down.is_pressed
    uptrue = up.is_pressed
    selecttrue = select.is_pressed
    if currentmenu == 99:
        draw_main(main_menu, indmain)
        if downtrue == True and indmain < len(main_menu)-1:
            indmain += 1
            
        if uptrue == True and indmain > 0:
            indmain -= 1
        
        if selecttrue == True and currentmenu == 99:
            currentmenu = indmain
    
    if currentmenu == 0:
        draw_submenu(MP3, indsub)
        if downtrue == True and indsub < len(MP3)-1:
            indsub += 1
            
        if uptrue == True and indsub > 0:
            indsub -= 1
        
        if selecttrue == True and MP3[indsub] == "Playlists":
            
        
        if selecttrue == True and MP3[indsub] == "Go back":
            currentmenu = 99
    
    if currentmenu == 1:
        draw_submenu()
    
    if currentmenu == 3:
        subprocess.run(["sudo", "poweroff"])
            





